# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS commiter le fichier .env sur GitHub !

SECRET_KEY=remplacez-par-une-clé-secrète-très-longue
DATABASE_URL=sqlite:///leboncap.db

# Brevo SMTP
BREVO_LOGIN=votre-login@brevo.com
BREVO_SMTP_KEY=votre-clé-smtp-brevo

# URL du site (pour les emails)
SITE_URL=https://votre-app.onrender.com

# Token secret pour le webhook cron automatique (résumé quotidien)
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET_TOKEN=generez-un-token-secret-long
